# Copy to .env for local development.
MONGO_URI=mongodb://localhost:27017
MONGO_DB=explainability
MONGO_COLLECTION=explanation_records
LOG_LEVEL=INFO

# Local dev: write proofs to disk. On Lambda this is set to s3 via template.yaml.
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=./data/proofs

# Required when STORAGE_BACKEND=s3
S3_BUCKET=
S3_PREFIX=proofs/
AWS_REGION=us-east-1

# Explanation tuning
# Violations >= this confidence (percent) are auto-approved; below = manual review.
AUTO_APPROVAL_THRESHOLD=90
